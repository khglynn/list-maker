# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (web/ is the Next.js app)
web/node_modules
web/.pnp
web/.pnp.*
web/.yarn/*
!web/.yarn/patches
!web/.yarn/plugins
!web/.yarn/releases
!web/.yarn/versions

# testing
web/coverage

# next.js
web/.next/
web/out/

# production
web/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code per-machine state — never sync via git.
# Only settings.local.json + worktrees stay machine-local; everything
# else under .claude/ (commands, hooks, agents, skills, mcp.json, plans)
# becomes trackable. Aligns with the cross-machine sync architecture in
# helper/claude-plans/2026-04-28-cross-machine-sync-architecture.md.
.claude/settings.local.json
.claude/worktrees/

# marketing assets (too large for git)
marketing/album_covers/
marketing/sop/tiles/
marketing/sop/output/
marketing/tal/tiles/
marketing/tal/output/

# Python virtual environment
pipeline/venv/

# cached episode data (JSON files from scrapers)
pipeline/_cache/

# Python cache
pipeline/__pycache__/
__pycache__/
*.pyc

# Session logs
pipeline/match_progress.log

# Batch extraction artifacts (large, regenerable)
codex-notes/ai-daily-entity-extraction/_full_runs/
codex-notes/ai-daily-entity-extraction/_guarded_runs/
codex-notes/ai-daily-entity-extraction/fullrun-*/
codex-notes/ai-daily-entity-extraction/recent50-*/
codex-notes/ai-daily-entity-extraction/incremental-*/
codex-notes/ai-daily-entity-extraction/historical-empty-retry-*/
codex-notes/ai-daily-entity-extraction/new-*/
codex-notes/ai-daily-entity-extraction/batch-*/

# Playwright MCP scratch (browser session logs)
.playwright-mcp/
